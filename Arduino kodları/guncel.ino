// ==========================================
// --- 3. PİN AYARLARI ---
// ==========================================
const byte ROWS = 2;
const byte COLS = 5;
char keys[ROWS][COLS] = {
  { '1', '2', '3', '4', '5' },
  { '6', '7', '8', '9', '0' }
};
byte rowPins[ROWS] = { 4, 5 };
byte colPins[COLS] = { 6, A0, A1, A2, A3 };
Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

Encoder enc1(7, 8);
Encoder enc2(10, 9);
const int enc1BtnPin = 14;
const int enc2BtnPin = 15;

// ==========================================
// --- 4. AKILLI ORTALAMA FONKSİYONU ---
// ==========================================
void ikonCiz(const unsigned char* ikon, String yazi1, String yazi2) {
  display.clearDisplay();

  // 1. İkonu Tam Ortaya Çiz (Ekran 128px, İkon 32px -> (128-32)/2 = X:48)
  display.drawBitmap(48, 2, ikon, 32, 32, WHITE);

  display.setTextSize(1);

  // 2. Matematiksel Yazi Ortalama Formülü
  // Her harf boyutu 6 pikseldir. (Ekran Genişliği - (Harf Sayısı * 6)) / 2
  int yazi1_X = (128 - (yazi1.length() * 6)) / 2;
  display.setCursor(yazi1_X, 38);
  display.print(yazi1);

  int yazi2_X = (128 - (yazi2.length() * 6)) / 2;
  display.setCursor(yazi2_X, 50);
  display.print(yazi2);

  display.display();
}

// ==========================================
// --- 5. SETUP ---
// ==========================================
void setup() {
  Consumer.begin();
  Keyboard.begin();

  pinMode(enc1BtnPin, INPUT_PULLUP);
  pinMode(enc2BtnPin, INPUT_PULLUP);

  if (display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    display.clearDisplay();
    display.setTextColor(WHITE);

    // Açılış yazısı da ortalansın
    display.setTextSize(2);
    String baslik = "MEOW DECK";
    int baslik_X = (128 - (baslik.length() * 12)) / 2;  // Boyut 2 olduğu için x12
    display.setCursor(baslik_X, 25);
    display.println(baslik);
    display.display();

    delay(2000);
    ikonCiz(ikon_tik, "SISTEM", "HAZIR");
    sonIslemZamani = millis();
  }
}

// ==========================================
// --- 6. LOOP ---
// ==========================================
void loop() {

  if (millis() - sonIslemZamani > BEKLEME_SURESI) {
    display.clearDisplay();
    float zaman = millis() / 200.0;
    int y1 = 16 + (int)(sin(zaman) * 6);
    int y2 = 16 + (int)(sin(zaman + 1.0) * 6);
    int y3 = 16 + (int)(sin(zaman + 2.0) * 6);
    display.drawBitmap(4, y1, ikon_kalp, 32, 32, WHITE);
    display.drawBitmap(48, y2, ikon_kalp, 32, 32, WHITE);
    display.drawBitmap(92, y3, ikon_kalp, 32, 32, WHITE);
    display.display();
  }

  char key = keypad.getKey();
  if (key) {
    sonIslemZamani = millis();

    switch (key) {

      case '1':
        micDurumu = !micDurumu;
        Keyboard.press(KEY_LEFT_CTRL);
        Keyboard.press(KEY_LEFT_SHIFT);
        Keyboard.press('m');
        delay(50);
        Keyboard.releaseAll();

        if (micDurumu) ikonCiz(ikon_mic_acik, "MIKROFON", "ACIK");
        else ikonCiz(ikon_mic_kapali, "MIKROFON", "KAPALI");
        break;

      case '2':
        kameraDurumu = !kameraDurumu;
        Keyboard.press(KEY_LEFT_CTRL);
        Keyboard.press(KEY_LEFT_SHIFT);
        Keyboard.press('v');
        delay(50);
        Keyboard.releaseAll();

        if (kameraDurumu) ikonCiz(ikon_camon, "KAMERA", "ACIK");
        else ikonCiz(ikon_camoff, "KAMERA", "KAPALI");
        break;

      case '3':
        Keyboard.press(KEY_LEFT_CTRL);
        Keyboard.press(KEY_LEFT_ALT);
        Keyboard.press('s');
        delay(50);
        Keyboard.releaseAll();
        ikonCiz(ikon_st, "YAYIN", "BASLADI");
        break;

      case '4':
        Keyboard.press(KEY_LEFT_GUI);
        Keyboard.press('d');
        delay(50);
        Keyboard.releaseAll();
        ikonCiz(ikon_desk, "MASAUSTU", "GOSTER");
        break;

      case '5':
        Keyboard.press(KEY_LEFT_GUI);
        Keyboard.press(KEY_LEFT_SHIFT);
        Keyboard.press('s');
        delay(50);
        Keyboard.releaseAll();
        ikonCiz(ikon_ss, "EKRAN", "GORUNTUSU");
        break;

      case '6':
        Keyboard.press(KEY_LEFT_CTRL);
        Keyboard.press('t');
        delay(50);
        Keyboard.releaseAll();
        ikonCiz(ikon_new, "YENI", "SEKME");
        break;

      case '7':
        Keyboard.press(KEY_LEFT_CTRL);
        Keyboard.press(KEY_LEFT_SHIFT);
        Keyboard.press(KEY_ESC);
        delay(50);
        Keyboard.releaseAll();
        ikonCiz(ikon_process, "GOREV", "YONETICISI");
        break;

      case '8':
        Keyboard.press('c');
        delay(50);
        Keyboard.releaseAll();
        ikonCiz(ikon_cut, "KURGU", "KESME ARACI");
        break;

      case '9':
        Keyboard.press(KEY_LEFT_GUI);
        Keyboard.press('l');
        delay(50);
        Keyboard.releaseAll();
        ikonCiz(ikon_kilit, "SISTEM", "KILITLENDI");
        break;

      case '0':
        Keyboard.press(KEY_LEFT_GUI);
        Keyboard.press('e');
        delay(50);
        Keyboard.releaseAll();
        ikonCiz(ikon_dosya, "DOSYA", "GEZGINI");
        break;
    }
  }

  long pos1 = enc1.read();
  if (pos1 >= 4) {
    sonIslemZamani = millis();
    Consumer.write(MEDIA_VOLUME_UP);
    ikonCiz(ikon_volup, "SES", "ARTTIRILDI");
    enc1.write(0);
  } else if (pos1 <= -4) {
    sonIslemZamani = millis();
    Consumer.write(MEDIA_VOLUME_DOWN);
    ikonCiz(ikon_voldown, "SES", "AZALTILDI");
    enc1.write(0);
  }

  if (digitalRead(enc1BtnPin) == LOW) {
    sonIslemZamani = millis();
    Consumer.write(MEDIA_VOLUME_MUTE);
    ikonCiz(ikon_volmute, "SES", "SUSTURULDU");
    delay(300);
  }

  long pos2 = enc2.read();
  if (pos2 >= 4) {
    sonIslemZamani = millis();
    Keyboard.write(KEY_DOWN_ARROW);
    ikonCiz(ikon_down, "SAYFA", "ASAGI");
    enc2.write(0);
  } else if (pos2 <= -4) {
    sonIslemZamani = millis();
    Keyboard.write(KEY_UP_ARROW);
    ikonCiz(ikon_up, "SAYFA", "YUKARI");
    enc2.write(0);
  }

  if (digitalRead(enc2BtnPin) == LOW) {
    sonIslemZamani = millis();
    Consumer.write(MEDIA_PLAY_PAUSE);
    ikonCiz(ikon_startstop, "MEDYA", "OYNAT/DUR");
    delay(300);
  }
}